{
  "manifest_version": 3,
  "name": "Extension Template",
  "version": "1.0.0",
  "description": "My youtube video to mp3 converter.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"]
    }
  ]
}
